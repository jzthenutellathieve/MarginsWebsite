<div class="mw-heading mw-heading2"><h2 id="Notable_alumni">Notable alumni</h2><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=City_University_of_Hong_Kong&amp;action=edit&amp;section=24" title="Edit section: Notable alumni"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
<ul><li><a href="/wiki/Rimsky_Yuen" title="Rimsky Yuen">Rimsky Yuen</a> - Former <a href="/w/index.php?title=Secretary_for_Justice_of_Hong_Kong&amp;action=edit&amp;redlink=1" class="new" title="Secretary for Justice of Hong Kong (page does not exist)">Secretary for Justice of Hong Kong</a>, Barrister<sup id="cite&#95;ref-52" class="reference"><a href="#cite_note-52"><span class="cite-bracket">&#91;</span>52<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Christine_Loh" title="Christine Loh">Christine Loh</a> – Former Undersecretary for the Environment<sup id="cite&#95;ref-53" class="reference"><a href="#cite_note-53"><span class="cite-bracket">&#91;</span>53<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Christopher_Cheung" title="Christopher Cheung">Christopher Cheung</a> – CEO of Christfund Securities and former Legislative Councillor<sup id="cite&#95;ref-54" class="reference"><a href="#cite_note-54"><span class="cite-bracket">&#91;</span>54<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/David_Chung_Wai-keung" title="David Chung Wai-keung">David Chung Wai-keung</a> – former Undersecretary for Innovation and Technology Bureau<sup id="cite&#95;ref-55" class="reference"><a href="#cite_note-55"><span class="cite-bracket">&#91;</span>55<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Kam_Nai-wai" title="Kam Nai-wai">Kam Nai-Wai</a> – Legislative Councillor<sup id="cite&#95;ref-56" class="reference"><a href="#cite_note-56"><span class="cite-bracket">&#91;</span>56<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Eunice_Yung" title="Eunice Yung">Eunice Yung Hoi-Yan</a> - Hong Kong Barrister and former member of the Legislative Council of Hong Kong</li>
<li><a href="/wiki/Bona_Mugabe" title="Bona Mugabe">Bona Mugabe</a> – Business woman, daughter of former president of Zimbabwe and ZANU-PF leader, Robert Mugabe<sup id="cite&#95;ref-57" class="reference"><a href="#cite_note-57"><span class="cite-bracket">&#91;</span>57<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Paul_Tse" title="Paul Tse">Paul Tse</a> – former Legislative Councillor<sup id="cite&#95;ref-58" class="reference"><a href="#cite_note-58"><span class="cite-bracket">&#91;</span>58<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Lau_Kong-wah" title="Lau Kong-wah">Lau Kong-Wah</a> – <a href="/wiki/Secretary_for_Home_Affairs" class="mw-redirect" title="Secretary for Home Affairs">Secretary for Home Affairs</a>, former undersecretary of the Constitutional and Mainland Affairs Bureau, former legislative councillor<sup id="cite&#95;ref-59" class="reference"><a href="#cite_note-59"><span class="cite-bracket">&#91;</span>59<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Matthew_Wong" title="Matthew Wong">Matthew Wong</a> – critically acclaimed painter<sup id="cite&#95;ref-60" class="reference"><a href="#cite_note-60"><span class="cite-bracket">&#91;</span>60<span class="cite-bracket">&#93;</span></a></sup><sup id="cite&#95;ref-61" class="reference"><a href="#cite_note-61"><span class="cite-bracket">&#91;</span>61<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Jozev_Kiu" title="Jozev Kiu">Jozev Kiu</a> – noted <a href="/wiki/Wuxia" title="Wuxia">wuxia</a> fiction writer and lyricist<sup id="cite&#95;ref-62" class="reference"><a href="#cite_note-62"><span class="cite-bracket">&#91;</span>62<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Fiona_Sit" title="Fiona Sit">Fiona Sit</a> – singer and actress<sup id="cite&#95;ref-63" class="reference"><a href="#cite_note-63"><span class="cite-bracket">&#91;</span>63<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Anson_Lo" title="Anson Lo">Anson Lo</a> – singer and actor; member of Hong Kong Cantopop group <a href="/wiki/Mirror_(group)" title="Mirror (group)">MIRROR</a><sup id="cite&#95;ref-auto&#95;64-0" class="reference"><a href="#cite_note-auto-64"><span class="cite-bracket">&#91;</span>64<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Alton_Wong" class="mw-redirect" title="Alton Wong">Alton Wong</a> – singer and actor; member of Hong Kong Cantopop group <a href="/wiki/Mirror_(group)" title="Mirror (group)">MIRROR</a><sup id="cite&#95;ref-auto&#95;64-1" class="reference"><a href="#cite_note-auto-64"><span class="cite-bracket">&#91;</span>64<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Ian_Chan" title="Ian Chan">Ian Chan</a> – singer and actor; member of Hong Kong Cantopop group <a href="/wiki/Mirror_(group)" title="Mirror (group)">MIRROR</a><sup id="cite&#95;ref-auto&#95;64-2" class="reference"><a href="#cite_note-auto-64"><span class="cite-bracket">&#91;</span>64<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Stanley_Yau" title="Stanley Yau">Stanley Yau</a> – singer and actor; member of Hong Kong Cantopop group <a href="/wiki/Mirror_(group)" title="Mirror (group)">MIRROR</a><sup id="cite&#95;ref-auto&#95;64-3" class="reference"><a href="#cite_note-auto-64"><span class="cite-bracket">&#91;</span>64<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Keith_Lam_(artist)" title="Keith Lam (artist)">Keith Lam</a> – new media artist who co-founded Dimension Plus<sup id="cite&#95;ref-65" class="reference"><a href="#cite_note-65"><span class="cite-bracket">&#91;</span>65<span class="cite-bracket">&#93;</span></a></sup> and founded openground.<sup id="cite&#95;ref-66" class="reference"><a href="#cite_note-66"><span class="cite-bracket">&#91;</span>66<span class="cite-bracket">&#93;</span></a></sup></li>
<li><a href="/wiki/Ivy_Ma" title="Ivy Ma">Ivy Ma</a> - Visual artist</li></ul>
